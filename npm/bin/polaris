#!/usr/bin/env bash
# ✦ Polaris Agent — npm bin wrapper
# This script is installed by npm as the `polaris` command.
# It locates the Python polaris CLI and execs it with all forwarded arguments.
set -e

# ── Locate Python polaris ─────────────────────────────────────────────────

# Try the standard pip-installed path first
POLARIS_PYTHON=""

# Check ~/.local/bin/polaris (pip --user install)
if [ -x "$HOME/.local/bin/polaris" ]; then
    exec "$HOME/.local/bin/polaris" "$@"
fi

# Check if polaris is in PATH (installed via pipx or system pip)
if command -v polaris &>/dev/null; then
    # Avoid recursion — if this script IS the polaris in PATH, skip
    POLARIS_CMD=$(command -v polaris)
    if [ "$POLARIS_CMD" != "$0" ]; then
        exec polaris "$@"
    fi
fi

# Check for pipx-installed
if [ -x "$HOME/.local/pipx/venvs/polaris-agent/bin/polaris" ]; then
    exec "$HOME/.local/pipx/venvs/polaris-agent/bin/polaris" "$@"
fi

# ── Try Python module directly ────────────────────────────────────────────

# Find a working Python 3.11+
for py in python3.12 python3.11 python3; do
    if command -v "$py" &>/dev/null; then
        VER=$("$py" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "0")
        MAJOR=$(echo "$VER" | cut -d. -f1)
        MINOR=$(echo "$VER" | cut -d. -f2)
        if [ "$MAJOR" -ge 3 ] && [ "$MINOR" -ge 11 ] 2>/dev/null; then
            # Check if polaris package is installed
            if "$py" -c "import cli.polaris_cli" 2>/dev/null; then
                exec "$py" -m cli.polaris_cli "$@"
            fi
        fi
    fi
done

# ── Not found ─────────────────────────────────────────────────────────────

cat >&2 << 'EOF'

  ✦ Polaris Agent is not fully installed yet.

  The npm package is a distribution wrapper. The Python package
  still needs to be installed. Choose one:

    1. pip install polaris-agent
    2. pipx install polaris-agent
    3. curl -sSL https://raw.githubusercontent.com/ZBcxy/polaris-agent/main/install.py | python3

  Then run: polaris

EOF
exit 1
