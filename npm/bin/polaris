#!/usr/bin/env node
/**
 * ✦ Polaris Agent — npm bin entry point
 *
 * This script locates the Python polaris CLI and execs it.
 * It's a thin wrapper — the real work is done by the Python package.
 */

const { spawnSync, execSync } = require("child_process");
const fs = require("fs");
const path = require("path");
const os = require("os");

function main() {
  const args = process.argv.slice(2);

  // ── Try 1: polaris in PATH (pip/pipx) ─────────────────────────────────
  const pathPolaris = findInPath("polaris");
  if (pathPolaris && pathPolaris !== __filename) {
    const result = spawnSync(pathPolaris, args, { stdio: "inherit" });
    process.exit(result.status ?? 1);
  }

  // ── Try 2: ~/.local/bin/polaris ──────────────────────────────────────
  const localBin = path.join(os.homedir(), ".local", "bin", "polaris");
  if (fs.existsSync(localBin)) {
    const result = spawnSync(localBin, args, { stdio: "inherit" });
    process.exit(result.status ?? 1);
  }

  // ── Try 3: pipx venv ─────────────────────────────────────────────────
  const pipxBin = path.join(os.homedir(), ".local", "pipx", "venvs", "polaris-agent", "bin", "polaris");
  if (fs.existsSync(pipxBin)) {
    const result = spawnSync(pipxBin, args, { stdio: "inherit" });
    process.exit(result.status ?? 1);
  }

  // ── Try 4: Python module directly ────────────────────────────────────
  const python = findPython();
  if (python) {
    // Check if polaris package is importable
    try {
      execSync(`"${python}" -c "import cli.polaris_cli"`, { stdio: "ignore" });
      const result = spawnSync(python, ["-m", "cli.polaris_cli", ...args], { stdio: "inherit" });
      process.exit(result.status ?? 1);
    } catch {
      // Package not installed yet
    }
  }

  // ── Not found ─────────────────────────────────────────────────────────
  console.error("");
  console.error("  ✦ Polaris Agent is not fully installed yet.");
  console.error("");
  console.error("  The npm package is a distribution wrapper. The Python package");
  console.error("  still needs to be installed. Choose one:");
  console.error("");
  console.error("    1. pip install polaris-agent");
  console.error("    2. pipx install polaris-agent");
  console.error("    3. curl -sSL https://raw.githubusercontent.com/ZBcxy/polaris-agent/main/install.py | python3");
  console.error("");
  console.error("  Then run: polaris");
  console.error("");
  process.exit(1);
}

function findInPath(cmd) {
  const paths = process.env.PATH.split(path.delimiter);
  for (const dir of paths) {
    const full = path.join(dir, cmd);
    if (fs.existsSync(full)) return full;
    // Windows
    if (process.platform === "win32" && fs.existsSync(full + ".exe")) return full + ".exe";
  }
  return null;
}

function findPython() {
  for (const py of ["python3.12", "python3.11", "python3", "python"]) {
    const p = findInPath(py);
    if (p) {
      try {
        const ver = execSync(`"${p}" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')"`, {
          encoding: "utf-8",
          stdio: ["ignore", "pipe", "ignore"],
        }).trim();
        const [major, minor] = ver.split(".").map(Number);
        if (major >= 3 && minor >= 11) return p;
      } catch {
        continue;
      }
    }
  }
  return null;
}

main();
