# ===========================================
# ✦ Polaris Agent — Navigate Complexity with AI
# Environment Configuration
# ===========================================
# cp .env.example .env

# --- LLM Provider (choose one) ---
OPENAI_API_KEY=sk-your-key-here
# OPENAI_API_BASE=https://api.openai.com/v1  # Custom endpoint (optional)
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
JWT_SECRET=change-this-to-a-random-secret
TOKEN_EXPIRE_HOURS=24
RATE_LIMIT_USER=100
CORS_ALLOW_ORIGINS=["*"]

# --- Agent Runtime ---
POLARIS_HOME=~/.polaris
POLARIS_LOG_LEVEL=INFO
POLARIS_AUTONOMY=L2
POLARIS_MAX_STEPS=20

# --- Memory & Storage ---
REDIS_HOST=localhost
REDIS_PORT=6379
MILVUS_HOST=localhost
MILVUS_PORT=19530
MEMORY_STORAGE_PATH=~/.polaris/memory/

# --- Local LLM (Ollama / vLLM / llama.cpp, no API key needed) ---
# LOCAL_LLM_PROVIDER=ollama
# LOCAL_LLM_MODEL=qwen3:8b
# LOCAL_LLM_URL=http://localhost:11434/v1

# --- Embedding ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
